{
  "name": "n8n-nodes-emboss",
  "version": "1.0.4",
  "description": "n8n node for Emboss — create fillable PDFs and fill forms from context.",
  "license": "MIT",
  "author": "Emboss <edwin@getemboss.ai>",
  "homepage": "https://getemboss.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GetEmboss-ai/n8n-nodes-emboss.git"
  },
  "bugs": {
    "url": "https://github.com/GetEmboss-ai/n8n-nodes-emboss/issues"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "emboss",
    "pdf",
    "forms"
  ],
  "scripts": {
    "build": "tsc && cp nodes/Emboss/emboss.svg dist/nodes/Emboss/emboss.svg",
    "test": "jest",
    "lint": "eslint nodes credentials --ext .ts"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/EmbossApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Emboss/Emboss.node.js"
    ]
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.7",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.55.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.5"
  }
}
